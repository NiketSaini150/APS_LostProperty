<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APS_LostProperty</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/APS_LostProperty.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark rounded fixed-top">

            <div class="container-fluid">
                <!-- Brand -->
                <a class="navbar-brand fw-bold text-light "  asp-controller="Home" asp-action="Index">
                    <img src="~/img/AvCol Logo White on Black Portrait.png" alt=" Logo" style="width:110px; height:80px" class=" rounded-pill" />|
                    Lost Property System
           
                </a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"       
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarSupportedContent">


                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active border border-primary rounded" : "")"  asp-controller="Home"  asp-action="Index">Home
                            </a>
                        </li>
                        @* STAFF ONLY LINKS *@
                        @if (User.IsInRole("Staff"))
                        {
                            <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" ? "active border border-primary rounded" : "")"  asp-controller="Categories" asp-action="Index">Categories</a>

                            <li class="nav-item">
                                <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Locations" ? "active border border-primary rounded" : "")"  asp-controller="Locations"  asp-action="Index">Locations
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "LostItems" ? "active border border-primary rounded" : "")"   asp-controller="LostItems"    asp-action="Index">Lost Items
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active border border-primary rounded" : "")" asp-controller="Admin" asp-action="Index">Admin
                                </a>
                            </li>
                        }

                        @* if the user is not a staff they are a user *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Claims" ? "active border border-primary rounded" : "")"  asp-controller="Claims" asp-action="Index">Claims
                                </a>
                            </li>
                        }
                    
                    </ul>

                    <!-- Search -->
                    <form class="d-flex text-dark" role="search" method="get" asp-controller="LostItems" asp-action="Index">
                        <input class="form-control form-control-sm me-2"
                               type="search"
                               name="searchString"
                               placeholder="Search items..." />

                        <button class="btn btn-sm btn-outline-light" type="submit">
                            Search
                        </button>
                    </form>

                    <!-- Login -->
                    <div class="ms-3 text-light">
                        <partial name="_LoginPartial" />
                    </div>

                </div>
            </div>
        </nav>
    </header>

    


    <!-- Main content -->
    <div class="container-fluid">
        <main role="main" class="pb-3 pt-5 ">
            @RenderBody()

        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted bg-dark text-white ">
        <div class=" text-white text-start">
            &copy; 2026 - Lost Property APP - <a asp-area="" class="btn btn-outline-light" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
        </footer>
    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>