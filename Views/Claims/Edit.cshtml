@model APS_LostProperty.Models.Claim

@{
    ViewData["Title"] = "Edit";
}
               <div class="card shadow-sm fs-2 p-4 mx-auto container pt-5 d-flex justify-content-center align-items-center" style="max-width: 80vh;">
                    <div style="height: 80vh;">

                        <div class="card-body mt-5">

                            <h2 class="text-center mb-3 fs1">Edit Claim</h2>
                            <hr />

                            <form asp-action="Edit" method="post">

                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="width:70vh"></div>

                                <input type="hidden" asp-for="ClaimID" />

                                <div class="mb-3">
                                    <label asp-for="ClaimedItemName" class="form-label"></label>
                                    <input asp-for="ClaimedItemName" class="form-control form-control-lg" />
                                    <span asp-validation-for="ClaimedItemName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ClaimedDescription" class="form-label"></label>
                                    <input asp-for="ClaimedDescription" class="form-control form-control-lg" />
                                    <span asp-validation-for="ClaimedDescription" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DateLost" class="form-label"></label>
                                    <input asp-for="DateLost" type="date" class="form-control form-control-lg" />
                                    <span asp-validation-for="DateLost" class="text-danger"></span>
                                </div>

                                @if (User.IsInRole("Staff"))
                                {
                                    <div class="mb-3">
                                        <label asp-for="Status" class="form-label"></label>
                                        <select asp-for="Status"
                                                class="form-control form-control-lg"
                                                asp-items="Html.GetEnumSelectList<APS_LostProperty.Models.ClaimStatus>()">
                                        </select>
                                        <span asp-validation-for="Status" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label asp-for="MatchedLostItemID" class="form-label"></label>
                                        <select asp-for="MatchedLostItemID"
                                                class="form-control form-control-lg"
                                                asp-items="ViewBag.MatchedLostItemID">
                                            <option value="">-- No Matching Item --</option>
                                        </select>
                                        <span asp-validation-for="MatchedLostItemID" class="text-danger"></span>
                                    </div>
                                }

                                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                                        Back to List
                                    </a>

                    <input type="submit" value="Save" class="btn btn-primary btn-lg" />
                                </div>

                            </form>

                        </div>
                    </div>
                </div>

                @section Scripts {
                    @{
                        await Html.RenderPartialAsync("_ValidationScriptsPartial");
                    }
                }
