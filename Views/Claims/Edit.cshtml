@model APS_LostProperty.Models.Claim

@{
    ViewData["Title"] = "Edit";
}
<div class="mx-auto fs-2" style="width:80%">
<h1>Edit Claim</h1>

<h4>Claim</h4>
<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ClaimID" />

            <div class="form-group">
                <label asp-for="ClaimedItemName" class="control-label"></label>
                <input asp-for="ClaimedItemName" class="form-control" />
                <span asp-validation-for="ClaimedItemName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ClaimedDescription" class="control-label"></label>
                <input asp-for="ClaimedDescription" class="form-control" />
                <span asp-validation-for="ClaimedDescription" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DateLost" class="control-label"></label>
                <input asp-for="DateLost" class="form-control" type="date" />
                <span asp-validation-for="DateLost" class="text-danger"></span>
            </div>

            @if (User.IsInRole("Staff"))
            {
                <div class="form-group">
                    <label asp-for="Status" class="control-label"></label>
                    <select asp-for="Status"
                            class="form-control"
                            asp-items="Html.GetEnumSelectList<APS_LostProperty.Models.ClaimStatus>()">
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            }
            @if (User.IsInRole("Staff"))
            {
                <div class="form-group">
                    <label asp-for="MatchedLostItemID" class="control-label"></label>

                    <select asp-for="MatchedLostItemID"
                            class="form-control"
                            asp-items="ViewBag.MatchedLostItemID">

                        <option value="">-- No Matching Item --</option>

                    </select>

                    <span asp-validation-for="MatchedLostItemID" class="text-danger"></span>
                </div>
            }

            <div class="form-group mt-2">
                <input type="submit" value="Save" class="btn btn-primary btn-lg" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary btn-md">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
</div>