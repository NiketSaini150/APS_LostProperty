@model IEnumerable<APS_LostProperty.Models.Claim>

@{
    ViewData["Title"] = "Index";
}

<h1>Claims</h1>
<form asp-action="Index" method="get" class="mb-3">

    <div class="input-group">

        <!-- search box -->
        <input type="text"
               name="searchString"
               value="@ViewBag.SearchString"
               class="form-control"
               placeholder="Search claims..." />

        <!-- search button -->
        <button type="submit" class="btn btn-primary">Search</button>

        <!-- clears search and resets page -->
        <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>

    </div>
</form>
<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.IdentityUser)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClaimedItemName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ClaimedDescription)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateLost)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateSubmitted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MatchedLostItem)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
                
                <td>
                    @Html.DisplayFor(model => item.IdentityUser.Email)
                </td>
            <td>
                    @Html.DisplayFor(modelItem => item.ClaimedItemName)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.ClaimedDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateLost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateSubmitted)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MatchedLostItem.ItemName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ClaimID"class="btn btn-light">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.ClaimID" class="btn btn-light">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.ClaimID" class="btn btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
<nav aria-label="Page navigation">

    <ul class="pagination">

        <!-- PREVIOUS BUTTON -->
        @if (ViewBag.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Previous
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Previous</span>
            </li>
        }

        <!-- PAGE NUMBERS -->
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <li class="page-item active">
                    <span class="page-link">@i</span>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">
                        @i
                    </a>
                </li>
            }
        }

        <!-- NEXT BUTTON -->
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Next
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Next</span>
            </li>
        }

    </ul>
</nav>
