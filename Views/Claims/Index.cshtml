@model IEnumerable<APS_LostProperty.Models.Claim>

@{
    ViewData["Title"] = "Index";
}

<div class="mx-auto" style="width:70%" >
<h1 >Claims</h1> 

<form asp-action="Index" method="get" class="mb-4">
  
    <div class="input-group shadow-sm">
 

        <!-- search box -->
        <input type="text"
               name="searchString"
               value="@ViewBag.SearchString"
               class="form-control"
               placeholder="Search claims..." />

        <!-- search button -->
        <button type="submit" class="btn btn-primary">Search</button>

      
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a> 

    </div>
</form>
<div class="row align-items-center mb-3">

    <div class="col-md-4">
            <a asp-action="Create" class="btn btn-success  btn-lg">
             Create New
        </a>
    </div>

    
   

  
    <div class="col-md-4"></div>

</div>


    
    <table class="table fs-4 table-striped table-hover align-middle mb-0">
        
        <thead class="rounded-pill">

            <tr >
                <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.IdentityUser )
            </th>
                <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.ClaimedItemName)
            </th>
            <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.ClaimedDescription)
            </th >
            <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.DateLost)
            </th>
                <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.DateSubmitted)
            </th>
            <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th class="bg-dark text-light text-start">
                @Html.DisplayNameFor(model => model.MatchedLostItem)
            </th>
                <th class="bg-dark text-light text-end"> Actions</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
                
                <td>
                    @Html.DisplayFor(model => item.IdentityUser.Email)
                </td>
            <td>
                    @Html.DisplayFor(modelItem => item.ClaimedItemName)
            </td>
            <td>
                    @Html.DisplayFor(modelItem => item.ClaimedDescription)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateLost)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateSubmitted)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MatchedLostItem.ItemName)
            </td>
                    <td class="text-end ">
                        <a asp-action="Edit" asp-route-id="@item.ClaimID" class="btn btn-light btn-lg">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.ClaimID" class="btn btn-light btn-lg">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.ClaimID" class="btn btn-danger btn-lg">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
<nav aria-label="Page navigation">

    <ul class="pagination">

        <!-- PREVIOUS BUTTON -->
        @if (ViewBag.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Previous
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Previous</span>
            </li>
        }

        <!-- PAGE NUMBERS -->
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <li class="page-item active">
                    <span class="page-link">@i</span>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">
                        @i
                    </a>
                </li>
            }
        }

        <!-- NEXT BUTTON -->
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Next
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Next</span>
            </li>
        }

    </ul>
</nav>
</div>