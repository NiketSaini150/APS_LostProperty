@model APS_LostProperty.Models.LostItem

@{
    ViewData["Title"] = "Create";
}

<div class="card shadow-sm fs-3 p-4 mx-auto container pt-4"
     style="max-width: 600px; width: 100%;">
    <div>

        <div class="card-body">

            <h1 class="text-center mb-3 fw-bold text-success" style="font-size: 2.2rem;">
                Create Lost Item
            </h1>

            <hr />

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="ItemName" class="form-label fw-semibold fs-4"></label>
                    <input asp-for="ItemName" class="form-control form-control-md" />
                    <span asp-validation-for="ItemName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold fs-4"></label>
                    <input asp-for="Description" class="form-control form-control-md" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DateFound" class="form-label fw-semibold fs-4"></label>
                    <input asp-for="DateFound" type="date" class="form-control form-control-md" />
                    <span asp-validation-for="DateFound" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryID" class="form-label fw-semibold fs-4"></label>
                    <select asp-for="CategoryID" class="form-control form-control-md" asp-items="ViewBag.CategoryID"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="LocationID" class="form-label fw-semibold fs-4"></label>
                    <select asp-for="LocationID" class="form-control form-control-md" asp-items="ViewBag.LocationID"></select>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="IsClaimed" />
                    <label class="form-check-label">
                        @Html.DisplayNameFor(model => model.IsClaimed)
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>
                    <input type="submit" value="Create" class="btn btn-success" />

                 
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}