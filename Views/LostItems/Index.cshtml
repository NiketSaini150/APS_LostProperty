@model IEnumerable<APS_LostProperty.Models.LostItem>

@{
    ViewData["Title"] = "Index";
}

<div class="container-fluid px-3">

    <div class="mx-auto" style="max-width: 1600px;">

        <h1>Lost Items</h1>

        <form asp-action="Index" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search LostItems..." />
                <button type="submit" class="btn btn-primary">Search</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>
            </div>
        </form>

        <p>
            <a asp-action="Create" class="btn btn-success btn-lg">Create New</a>
        </p>

        <div class="table-responsive">

            <table class="table fs-4 table-striped table-hover">

                <thead>
                    <tr>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.ItemName)
                        </th>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.Description)
                        </th>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.DateFound)
                        </th>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.Category)
                        </th>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.Location)
                        </th>
                        <th class="bg-dark text-light text-start">
                            @Html.DisplayNameFor(model => model.IsClaimed)
                        </th>
                        <th class="bg-dark text-light text-end">
                            Actions
                        </th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.ItemName)</td>

                            <td style="max-width: 250px; word-break: break-word;">
                                @(item.Description?.Length > 30
                                    ? item.Description.Substring(0, 30) + "..."
                                    : item.Description)
                            </td>

                            <td>@Html.DisplayFor(modelItem => item.DateFound)</td>

                            <td>@Html.DisplayFor(modelItem => item.Category.Name)</td>

                            <td>@Html.DisplayFor(modelItem => item.Location.LocationName)</td>

                            <td>@Html.DisplayFor(modelItem => item.IsClaimed)</td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.LostItemID" class="btn btn-light btn-md">Edit</a> |
                                <a asp-action="Details" asp-route-id="@item.LostItemID" class="btn btn-light btn-md">Details</a> |
                                <a asp-action="Delete" asp-route-id="@item.LostItemID" class="btn btn-danger btn-md">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <nav aria-label="Page navigation">

            <ul class="pagination flex-wrap">

                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-searchString="@ViewBag.SearchString">
                            Previous
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">Previous</span>
                    </li>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <li class="page-item active">
                            <span class="page-link">@i</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchString="@ViewBag.SearchString">
                                @i
                            </a>
                        </li>
                    }
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-searchString="@ViewBag.SearchString">
                            Next
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link">Next</span>
                    </li>
                }

            </ul>

        </nav>

    </div>
</div>