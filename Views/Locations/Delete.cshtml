@model APS_LostProperty.Models.Location

@{
    ViewData["Title"] = "Delete";
}

<div class="card shadow-sm fs-3 p-4 mx-auto container pt-4"
     style="max-width: 900px; width: 100%;">
    <div>

        <div class="card-body mt-5">

            <h1 class="text-center mb-3 fw-bold text-danger" style="font-size: 2.2rem;">
                Delete Location
            </h1>

            <hr />

            <h3 class="mb-3 text-center" style="font-size: 1.5rem;">
                Are you sure you want to delete this?
            </h3>

            <hr />

            <dl class="row mb-4">

                <dt class="col-sm-4 fw-semibold fs-4">
                    @Html.DisplayNameFor(model => model.LocationName)
                </dt>
                <dd class="col-sm-8 fs-5">
                    @Html.DisplayFor(model => model.LocationName)
                </dd>

            </dl>

            <form asp-action="Delete">

                <input type="hidden" asp-for="LocationID" />

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>

                    <input type="submit" value="Delete" class="btn btn-danger" />
                </div>

            </form>

        </div>

    </div>
</div>