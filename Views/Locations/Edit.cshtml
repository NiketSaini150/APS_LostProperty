@model APS_LostProperty.Models.Location

@{
    ViewData["Title"] = "Edit";
}

<div class="card shadow-sm fs-2 p-4 mx-auto container pt-5 d-flex justify-content-center align-items-center" style="max-width: 80vh;">
    <div style="height: 80vh;">

        <div class="card-body mt-5">

            <h1 class="text-center mb-3 fs-1"> Edit</h1>

<h4 class="mb-3">>Location</h4>
            <hr />

   
        <form asp-action="Edit">
                <div class="mb-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="LocationID" />
                </div>

                        

                    <div class="mb-3">
                <label asp-for="LocationName" class="control-label"></label>
                    <input asp-for="LocationName" class="form-control  form-control-lg" />
                <span asp-validation-for="LocationName" class="text-danger"></span>
            </div>
        
                        

                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                                        Back to List
                                    </a>

                    <input type="submit" value="Save" class="btn btn-primary btn-lg" />
                                </div>
        </form>
    </div>
</div>




@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</div>

