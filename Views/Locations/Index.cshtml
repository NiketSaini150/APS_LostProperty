@model IEnumerable<APS_LostProperty.Models.Location>

@{
    ViewData["Title"] = "Index";
}
<div class="mx-auto" style=" width:95rem">
<h1>Locations</h1>

<!-- Search Form -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search locations..." />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>
    </div>
</form>
<p>
    <a asp-action="Create" class="btn btn-success btn-lg ">Create New</a>
</p>

<table class=" fs-4 table table-hover table-striped" >
    <thead class="rounded-pill" >
        <tr>
            <th class="bg-dark  text-light text-start" >
                Location Name
             @*    @Html.DisplayNameFor(model => model.LocationName) *@
            </th>
            <th class="bg-dark text-light text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.LocationName)
                </td>
                <td class="text-end ">
                    <div class="btn-group" role="group" aria-label="Actions ">
                        <a asp-action="Edit" asp-route-id="@item.LocationID" class="btn btn-light btn-lg">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.LocationID" class="btn btn-light btn-lg">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.LocationID" class="btn btn-danger btn-lg">Delete</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
<nav aria-label="Page navigation">

    <ul class="pagination">

        <!-- PREVIOUS BUTTON -->
        @if (ViewBag.CurrentPage > 1)
        {
            <li class="page-item " >
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Previous
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Previous</span>
            </li>
        }

        <!-- PAGE NUMBERS -->
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            if (i == ViewBag.CurrentPage)
            {
                <li class="page-item active">
                    <span class="page-link">@i</span>
                </li>
            }
            else
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">
                        @i
                    </a>
                </li>
            }
        }

        <!-- NEXT BUTTON -->
        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <li class="page-item " >
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Next
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link">Next</span>
            </li>
        }

    </ul>
</nav>
</div>