@{
    ViewData["Title"] = "Home Page";
}

<h1>Lost Property Management System</h1>

<p>
    This system helps students and staff report, track, and manage lost and found items.
</p>

<hr />

<h2>Navigation</h2>

<ul>
    <li>
        <a asp-controller="LostItems" asp-action="Index">View Lost Items</a>
    </li>
    <li>
        <a asp-controller="Claims" asp-action="Index">View Claims</a>
    </li>
    <li>
        <a asp-controller="Admin" asp-action="Index">Admin Panel</a>
    </li>
</ul>

<h2>How It Works</h2>

<ul>
    <li>Items are logged when found.</li>
    <li>Users can search for their items.</li>
    <li>Claims are submitted for lost items.</li>
    <li>Staff review and return matched items.</li>
</ul>