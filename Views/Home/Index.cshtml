@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background-color: #0f0f10;
        color: #e6e6e6;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial;
    }

    .page-container {
        max-width: 1200px;
        margin: auto;
    }

    /* HERO */
    .hero {
        background-color: #171717;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 40px;
        margin-top: 20px;
    }

        .hero h1 {
            font-size: 32px;
            font-weight: 600;
            color: #ffffff;
        }

        .hero p {
            color: #b5b5b5;
        }

    hr {
        border-color: #2a2a2a;
    }

    /* COUNTERS */
    .counter-card {
        background-color: #171717;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 20px;
        transition: 0.2s ease;
    }

        .counter-card:hover {
            border-color: #3a3a3a;
            background-color: #1b1b1b;
        }

    .counter-value {
        font-size: 28px;
        font-weight: 700;
    }

    .text-muted-custom {
        color: #9ca3af;
        font-size: 13px;
    }

    .text-blue {
        color: #60a5fa;
    }

    .text-green {
        color: #34d399;
    }

    .text-purple {
        color: #a78bfa;
    }

    /* QUICK ACTION CARDS */
    .action-card {
        background-color: #171717;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 20px;
        height: 100%;
        transition: 0.2s ease;
    }

        .action-card:hover {
            border-color: #3a3a3a;
            transform: translateY(-2px);
        }

        .action-card h5 {
            color: #ffffff;
        }

        .action-card p {
            color: #b5b5b5;
            font-size: 13px;
        }

    .btn-dark {
        background-color: #2a2a2a;
        border: 1px solid #3a3a3a;
        color: #e6e6e6;
    }

        .btn-dark:hover {
            background-color: #333;
        }

    .btn-blue {
        background-color: #2563eb;
        color: white;
        border: none;
    }

        .btn-blue:hover {
            background-color: #1d4ed8;
        }

    .btn-green {
        background-color: #059669;
        color: white;
        border: none;
    }

        .btn-green:hover {
            background-color: #047857;
        }

    /* INFO SECTION */
    .info-box {
        margin-top: 40px;
        padding: 25px;
        background-color: #171717;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
    }

        .info-box h4 {
            color: #ffffff;
        }

        .info-box li {
            color: #b5b5b5;
            margin-bottom: 6px;
        }
</style>

<div class="page-container">

    <!-- HERO -->
    <div class="hero">

        <h1>Lost Property Management System</h1>

        <p>
            A system designed to help students and staff efficiently report, track, and manage lost and found items within the school.
        </p>

        <hr />

        <p>
            Use the system to browse lost items, submit claims, and manage categories and locations.
        </p>

    </div>

    <!-- COUNTERS -->
    <div class="row text-center mt-4">

        <div class="col-md-4 mb-3">
            <div class="counter-card">
                <div class="counter-value text-blue">@ViewBag.TotalItems</div>
                <div class="text-muted-custom">Total Lost Items</div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="counter-card">
                <div class="counter-value text-green">@ViewBag.TotalClaims</div>
                <div class="text-muted-custom">Total Claims</div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="counter-card">
                <div class="counter-value text-purple">@ViewBag.TotalCategories</div>
                <div class="text-muted-custom">Total Categories</div>
            </div>
        </div>

    </div>

    <!-- ACTION CARDS -->
    <div class="row text-center mt-3">

        <div class="col-md-4 mb-3">
            <div class="action-card">

                <h5>Lost Items</h5>
                <p>Browse all found items and check if yours has been logged.</p>

                <a asp-controller="LostItems" asp-action="Index" class="btn btn-blue btn-sm">
                    View Items
                </a>

            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="action-card">

                <h5>Claims</h5>
                <p>Submit or track a claim for your lost belongings.</p>

                <a asp-controller="Claims" asp-action="Index" class="btn btn-green btn-sm">
                    View Claims
                </a>

            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="action-card">

                <h5>System Admin</h5>
                <p>Manage categories, locations, and SQL queries.</p>

                <a asp-controller="Admin" asp-action="Index" class="btn btn-dark btn-sm">
                    Open Admin
                </a>

            </div>
        </div>

    </div>

    <!-- INFO -->
    <div class="info-box">

        <h4>How the System Works</h4>

        <ul>
            <li>Items are logged when found around the school.</li>
            <li>Users search using keywords.</li>
            <li>Claims are submitted and reviewed by staff.</li>
            <li>Items are matched and returned to owners.</li>
        </ul>

    </div>

</div>