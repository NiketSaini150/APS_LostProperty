@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">

    <!-- HERO SECTION -->
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">

        <div class="container-fluid py-3">

            <h1 class="display-5 fw-bold">Lost Property Management System</h1>

            <p class="col-md-8 fs-5">
                A system designed to help students and staff efficiently report, track, and manage lost and found items within the school.
            </p>

            <hr />

            <p>
                Use the navigation bar to browse lost items, submit claims, or manage system data like categories and locations.
            </p>

        </div>
    </div>

    <!-- LIVE COUNTERS SECTION -->
    <div class="row text-center mb-4">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="fw-bold text-primary">@ViewBag.TotalItems</h2>
                    <p class="text-muted mb-0">Total Lost Items</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="fw-bold text-success">@ViewBag.TotalClaims</h2>
                    <p class="text-muted mb-0">Total Claims</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="fw-bold text-dark">@ViewBag.TotalCategories</h2>
                    <p class="text-muted mb-0">Total Categories</p>
                </div>
            </div>
        </div>

    </div>

    <!-- QUICK ACTION CARDS -->
    <div class="row text-center">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h5 class="card-title">Lost Items</h5>
                    <p class="card-text">
                        Browse all found items and check if yours has been logged.
                    </p>

                    <a asp-controller="LostItems" asp-action="Index" class="btn btn-primary">
                        View Items
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h5 class="card-title">Claims</h5>
                    <p class="card-text">
                        Submit or track a claim for your lost belongings.
                    </p>

                    <a asp-controller="Claims" asp-action="Index" class="btn btn-success">
                        View Claims
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h5 class="card-title">System Management</h5>
                    <p class="card-text">
                        Manage categories and locations in the system.
                    </p>

                    <a asp-controller="Categories" asp-action="Index" class="btn btn-dark">
                        Open Admin
                    </a>

                </div>
            </div>
        </div>

    </div>

    <!-- INFO SECTION -->
    <div class="mt-5 p-4 bg-white rounded shadow-sm">

        <h4>How the System Works</h4>

        <ul>
            <li>Items are logged when found around the school.</li>
            <li>Users search for lost belongings using keywords.</li>
            <li>Claims are submitted and reviewed by staff.</li>
            <li>Items are matched and returned to owners.</li>
        </ul>

    </div>

</div>