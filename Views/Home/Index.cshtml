@{
    ViewData["Title"] = "Home Page";
}

<h1>Lost Property Management System</h1>

<h4>
    Welcome to the lost property webapp, This system helps students report items they have lost. 
    Helps Staff, track, and manage lost and found items.

    If you are a student and have lost an item please register to make a claim about your lost item.
    Then the staff will later review it and contact you though your email if the item is found. 
    
</h4>

<hr />

<h2>Navigation</h2>

<ul class="d-flex gap-3 list-unstyled "  >
    <li>
        <a asp-controller="LostItems" asp-action="Index" class="btn btn-primary">View Lost Items</a>
    </li>
    <li>
        <a asp-controller="Claims" asp-action="Index" class="btn btn-primary">View Claims</a>
    </li>
    <li>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">Admin Panel</a>
    </li>
</ul>


<div id="demo" class="carousel slide" data-bs-ride="carousel">



    <!-- The slideshow/carousel -->
    <div id="demo" class="carousel slide" data-bs-ride="carousel">

        <div class="carousel-indicators">
            <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/Img/Avondale_College_D_Block.jpg" class="d-block w-100" alt="avondale college ">
            </div>
            <div class="carousel-item">
                <img src="~/Img/Lost property.jpg" class="d-block w-100" alt=" lost property">
            </div>
            <div class="carousel-item">
                <img src="~/Img/sports.jpg" class="d-block w-100" alt="sports">
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>

    </div>
    <h4>How It Works</h4>


    <h3>
        if you are a student and have lost an item please register to make a claim about your lost item.
        Then the staff will later review it and contact you though your email if the item is found.

        After Registering click on the claims tab, then select create this will take you to a form where you will be able to input ino
        Users can search for their items.
        Claims are submitted for lost items.
        Staff review and return matched items.
    </h3>
