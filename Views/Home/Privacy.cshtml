@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="card shadow-sm p-4 mx-auto container mt-5"
     style="max-width: 900px; width: 100%;">

    <div class="card-body">

        <h1 class="text-center mb-4 fw-bold" style="font-size: 2.2rem;">
            Privacy Policy
        </h1>

        <hr />

        <p>
            APS Lost Property is committed to protecting your privacy and
            ensuring that your personal information is handled securely.
        </p>

        <h4 class="mt-4">Information We Collect</h4>
        <p>
            We may collect personal information such as your name, email
            address, phone number, and details relating to lost property
            claims submitted through the system.
        </p>

        <h4 class="mt-4">How We Use Your Information</h4>
        <p>
            The information collected is used to manage lost property records,
            process ownership claims, communicate with users, and improve the
            functionality of the system.
        </p>

        <h4 class="mt-4">Data Security</h4>
        <p>
            Reasonable measures are taken to protect your information from
            unauthorized access, disclosure, or misuse.
        </p>

        <h4 class="mt-4">Sharing Information</h4>
        <p>
            Personal information will not be shared with third parties unless
            required by law or necessary for the operation of the service.
        </p>

        <h4 class="mt-4">Contact Us</h4>
        <p class="mb-0">
            If you have any questions regarding this Privacy Policy, please
            contact the system administrator.
        </p>

    </div>

</div>