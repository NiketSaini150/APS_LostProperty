@model APS_LostProperty.Models.Category

@{
    ViewData["Title"] = "Create";
}

<div class="card shadow-sm fs-3 p-4 mx-auto container pt-4"
     style="max-width: 600px; width: 100%;">
    <div>

        <div class="card-body">

            <h1 class="text-center mb-3 fw-bold text-success" style="font-size: 2.2rem;">
                Create Category
            </h1>

            <hr />

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold fs-4"></label>
                    <input asp-for="Name" class="form-control form-control-md" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        Back to List
                    </a>
                    <input type="submit" value="Create" class="btn btn-success" />

                 
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}