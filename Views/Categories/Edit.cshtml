@model APS_LostProperty.Models.Category

@{
    ViewData["Title"] = "Edit";
}
<div class="mx-auto fs-2" style="width:80%">
<h1>Edit</h1>

<h4>Category</h4>
<hr />
<div class="mx-auto" style="width:70%">
<div class="row" style="align-content">
    <div class="col-md">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CategoryID" />
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger btn-lg"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-light btn-lg" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary btn-lg">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</div>